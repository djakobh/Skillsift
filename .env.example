# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Next Auth
# You can generate a new secret on the command line with:
# npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET="enter_your_auth_secret_here" # Generated by create-t3-app.

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="enter_your_database_url_here"

# AI Usage
GROQ_API_KEY="enter_your_groq_api_key_here"
GEMINI_API_KEY="enter_your_gemini_api_key_here"

# Adzuna Key
ADZUNA_APP_ID="enter_your_adzuna_app_id_here"
ADZUNA_APP_KEY="enter_your_adzuna_app_key_here"

# AssemblyAI Key
ASSEMBLY_AI_API_KEY="enter_your_assemblyai_api_key_here"

# Resend Key
RESEND_API_KEY="enter_your_resend_api_key_here"
# Sender address — must be from a verified domain in your Resend account
# Use onboarding@resend.dev for testing (sends only to your registered email)
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Railway for Code Execution + Video Analysis
# 2 separate Railway projects are used for code execution and video analysis to ensure that the services can scale independently based on demand. The code runner service handles executing user-submitted code, while the analyzer service processes and analyzes video content. Both services are hosted on Railway
# Provides a seamless deployment experience and allows for easy scaling as needed.
CODE_RUNNER_URL="enter_your_code_runner_url_here"
PORT="enter_your_port_here"
ANALYZER_URL="enter_your_analyzer_url_here"
ANALYZER_SECRET="enter_your_analyzer_secret_here"
